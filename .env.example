# Baane Logistics - Environment Configuration
# Copy this file to .env and fill in your values

# Google Gemini API Key for AI Copilot feature
# Get your key at: https://aistudio.google.com/apikey
# If not set, the AI Copilot will use offline fallback responses
GEMINI_API_KEY=

# Server port (default: 3000)
PORT=3000
